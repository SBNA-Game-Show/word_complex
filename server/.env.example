# Server environment variables. Copy to server/.env and fill in real values.

# MongoDB Atlas connection string (database: word_complex)
ATLAS_URI=

# Port the API listens on (defaults to 5000 if unset)
PORT=5000

# Firebase Admin credentials — required for the admin routes (/api/v1/admin/*,
# PUT /api/v1/stories/tokenized/:id). Paste the FULL JSON of a Firebase service
# account key as a single line (Firebase console → Project settings → Service
# accounts → Generate new private key).
# Example: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}
FIREBASE_SERVICE_ACCOUNT_JSON=
